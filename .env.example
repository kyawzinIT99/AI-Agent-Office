# OpenAI (required)
OPENAI_API_KEY=sk-proj-your-openai-key-here

# GitHub (required — needs 'repo' scope)
GITHUB_TOKEN=ghp_your-github-token-here
GITHUB_REPO=yourname/yourrepo

# Jira (optional — leave placeholder to skip gracefully)
JIRA_SERVER=https://your-domain.atlassian.net
JIRA_EMAIL=you@example.com
JIRA_API_TOKEN=your-jira-api-token-here
JIRA_PROJECT_KEY=ENG

# Database
DATABASE_URL=sqlite:///./database/agentoffice.db

# Scheduler (24h UTC — agents auto-run daily at this time)
SCHEDULER_HOUR=9
SCHEDULER_MINUTE=0
